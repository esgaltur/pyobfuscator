% ============================================
% White Paper Citation
% ============================================

@techreport{sosnovic2026pyobfuscator,
  author       = {Sosnovic, Dmitrij},
  title        = {{PyObfuscator}: A Multi-Layer Defense Framework for Python Code Protection},
  institution  = {Independent Research},
  year         = {2026},
  month        = {January},
  type         = {White Paper},
  url          = {https://github.com/esgaltur/pyobfuscator/blob/main/docs/WHITEPAPER.md},
  abstract     = {This paper presents PyObfuscator, an open-source Python code protection
                  framework that implements a defense-in-depth strategy through multiple
                  complementary security layers. The framework combines Abstract Syntax Tree
                  (AST) transformations, AES-256-GCM encryption with PBKDF2 key derivation,
                  polymorphic runtime generation, code virtualization, and comprehensive
                  anti-analysis techniques.}
}

